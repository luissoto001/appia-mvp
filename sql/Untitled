create table if not exists tickets (
  id bigint generated always as identity primary key,
  ticket_numero text not null unique,
  cliente_id bigint not null references clientes_demo(id) on delete cascade,
  bpi text not null references servicios(bpi) on delete cascade,
  tipo_solicitud text not null,
  descripcion text,
  estado text not null default 'Ingresado',
  area_resolutora text not null default 'Soporte Técnico',
  tipologia text not null default 'General',
  fecha_estimada timestamptz,
  created_at timestamptz default now()
);